{
  "name": "syntaxnode",
  "version": "1.0.0",
  "description": "Production-grade AI Agent CLI Tool",
  "main": "dist/index.js",
  "bin": {
    "syntaxnode": "dist/index.js"
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.1",
    "axios": "^1.16.0",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "execa": "^5.1.1",
    "inquirer": "^8.2.6",
    "open": "^11.0.0",
    "ora": "^5.4.1",
    "puppeteer": "^24.42.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.10.4",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
